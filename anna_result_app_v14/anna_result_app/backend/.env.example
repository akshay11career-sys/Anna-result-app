# Anna University Result Analyzer - Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME=Anna University Result Analyzer
DEBUG=false

# Database (SQLite - default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./anna_results.db

# Database (PostgreSQL - uncomment to use)
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/anna_results

# CORS - Frontend URL(s)
# ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# Export
EXPORT_DIR=./exports
